# ===== Catice Backend — ตัวอย่างค่า environment =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง:  cp .env.example .env
# .env ถูก git ignore แล้ว (ดู .gitignore) — อย่า commit ค่าลับขึ้น repo

# ---- HTTP server ----
# ที่อยู่ที่ backend ฟัง (รูปแบบ host:port; เว้น host = ฟังทุก interface)
ADDR=:8080

# ---- JWT ----
# กุญแจลับเซ็น/ตรวจ JWT (HS256) — production ต้องเป็นค่าสุ่มยาว ๆ และเก็บเป็นความลับ
# สร้างค่าสุ่ม:  openssl rand -hex 32
JWT_SECRET=dev-secret-change-me

# ---- Postgres (บังคับ — ไม่มีไม่ start) ----
# แอปอ่าน DATABASE_URL ตัวเดียว; ตัวแปร POSTGRES_* / DATABASE_PORT ด้านล่าง
# มีไว้ประกอบ DSN และให้ docker-compose ใช้ตั้งค่า container db
DATABASE_HOST=localhost
DATABASE_PORT=5432
POSTGRES_USER=catice
POSTGRES_PASSWORD=catice
POSTGRES_DB=catice
DATABASE_URL=postgres://catice:catice@localhost:5432/catice?sslmode=disable

# ---- Redis (ไม่บังคับ) ----
# ว่าง = ไม่เก็บตำแหน่งถาวร (reconnect แล้ว spawn ใหม่)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
